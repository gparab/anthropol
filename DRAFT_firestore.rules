rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerifiedUser() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { return isSignedIn() && request.auth.token.email == 'parabgautam@gmail.com'; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Entity Validations ---
    
    function isValidClient(data) {
      return data.keys().hasAll(['name', 'tier', 'createdAt']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.tier in ['standard', 'enterprise'] &&
             data.createdAt is timestamp &&
             (!data.keys().hasAny(['usage']) || (
               data.usage.currentMonth is int &&
               data.usage.limit is int
             )) &&
             (!data.keys().hasAny(['apiKeys']) || (
               data.apiKeys.publicKey is string &&
               data.apiKeys.secretKey is string
             ));
    }

    function isValidVerification(data) {
      return data.keys().hasAll(['clientId', 'status', 'timestamp', 'score']) &&
             data.clientId == request.auth.uid &&
             data.status in ['passed', 'failed', 'processing'] &&
             data.timestamp == request.time &&
             data.score is number && data.score >= 0 && data.score <= 100 &&
             (!data.keys().hasAny(['signals']) || data.signals is map) &&
             (!data.keys().hasAny(['rawSamples']) || (data.rawSamples is list && data.rawSamples.size() <= 1000));
    }

    function isValidWebhookLog(data) {
      return data.keys().hasAll(['clientId', 'url', 'type', 'status', 'timestamp']) &&
             data.clientId == request.auth.uid &&
             data.url is string && data.url.size() <= 500 &&
             data.type is string &&
             data.status is int &&
             data.timestamp == request.time;
    }

    // --- Collection Routes ---

    // 1. Clients
    match /clients/{clientId} {
      allow get: if isOwner(clientId) || isAdmin();
      allow create: if isOwner(clientId) && isValidClient(incoming()) && incoming().createdAt == request.time;
      allow update: if (isOwner(clientId) || isAdmin()) && (
        // Action: Standard Update (name, settings)
        (incoming().diff(existing()).affectedKeys().hasOnly(['name', 'privacySettings', 'apiKeys', 'legalZone']) && isValidClient(incoming())) ||
        // Action: Usage Increment (system usually, but we allow owner/admin for this app's logic)
        (incoming().diff(existing()).affectedKeys().hasOnly(['usage']) && isValidClient(incoming())) ||
        // Action: Tier Upgrade
        (incoming().diff(existing()).affectedKeys().hasOnly(['tier', 'usage']) && isValidClient(incoming())) ||
        isAdmin()
      );
    }

    // 2. Verifications
    match /verifications/{verificationId} {
      allow get: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow create: if isVerifiedUser() && isValidVerification(incoming());
      // verifications are immutable
      allow update, delete: if isAdmin();
    }

    // 3. Verifications Recovery (Failover)
    match /verifications_recovery/{recoveryId} {
      allow create: if isVerifiedUser() && isValidVerification(incoming());
      allow read, delete: if isAdmin();
    }

    // 4. Webhook Logs
    match /webhook_logs/{logId} {
      allow get: if isSignedIn() && (existing().clientId == request.auth.uid || isAdmin());
      allow list: if isSignedIn() && (resource.data.clientId == request.auth.uid || isAdmin());
      allow create: if isVerifiedUser() && isValidWebhookLog(incoming());
      allow update, delete: if isAdmin();
    }

    // 5. Global Stats
    match /system/global {
      allow get: if isSignedIn();
      allow update: if isSignedIn() && (
        // Action: Increment Stats
        incoming().diff(existing()).affectedKeys().hasAny(['totalVerifications', 'botInterceptions']) ||
        isAdmin()
      );
    }
  }
}
