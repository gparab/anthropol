# Anthropol.io Environment Blueprint
# Copy this to .env and provide your production secrets.

# Firebase Service Account (JSON string or path)
# Optional in Cloud Run as it uses the default service account
FIREBASE_PROJECT_ID=

# Webhook Security
# Used to sign outgoing identity attestations
ANTHROPOL_WEBHOOK_SECRET=

# Regional Shard Passwords (for encrypted communication between nodes)
SHARD_EU_SECRET=
SHARD_APAC_SECRET=
